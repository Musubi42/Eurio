# Secrets
.env
local.properties

# Nix
result
.direnv/

# IDE
.idea/

# OS
.DS_Store

# Gradle
.gradle/

.envrc

# Filament toolchain (matc) — installed locally via `go-task filament:install-matc`,
# pinned to v1.71.0 to match the runtime shipped in SceneView 4.0.0.
tools/filament/

# Compiled Filament materials — generated from app-android/src/main/materials/*.mat
# by `go-task filament:compile-materials` (auto-run by Gradle preBuild).
app-android/src/main/assets/materials/

# ML artifacts
# Heavy ML training datasets (images, embeddings, etc.) — keep referential and snapshots
ml/datasets/*
# !ml/datasets/eurio_referential.json
# !ml/datasets/country_mapping.json
# !ml/datasets/sources/
# ml/datasets/sources/*
# !ml/datasets/sources/*.html
# !ml/datasets/sources/*.json
# !ml/datasets/sources/*.jsonl
ml/__pycache__/
ml/*.pth
ml/*.tflite
ml/*.npy
ml/checkpoints/
ml/output/
ml/yolov8n.pt
ml/.ebay_token_cache.json
ml/.dataset_cache/
ml/state/training.db
ml/state/training.db-wal
ml/state/training.db-shm
ml/cache/dinov2_inputs/*.webp

# Real-photo benchmark hold-out — NEVER committed. These photos are the
# ground truth for PRD Bloc 3 and must remain strictly off-training (see
# `docs/augmentation-benchmark/03-real-photo-benchmark.md §7 R1`).
ml/data/real_photos/
ml/reports/

# YOLO training env + outputs (NixOS 1080 Ti)
yolo_env/
runs/
yolo*.pt

# App test/temp models
app-android/src/main/assets/models/test_model.tflite
ml/debug_captures/eurio_debug

# Debug captures pulled from device (via `go-task android:pull-debug`)
debug_pull/

# Python
__pycache__/
*.pyc
.venv/

# Kotlin build errors
.kotlin/

# Node
node_modules/
dist/
.vite/

# Screenshots at root
Screenshot_*.png

# Parity screenshots (captured locally, not committed)
admin/packages/parity/screenshots/proto/*
!admin/packages/parity/screenshots/proto/.gitignore
admin/packages/parity/screenshots/android/*
!admin/packages/parity/screenshots/android/.gitignore
