// Eurio coin face material — lit PBR with photo as albedo + Sobel-derived
// normal map for surface relief. Compiled by `go-task filament:compile-materials`
// (auto-run by Gradle preBuild) into assets/materials/coin_face.filamat.
//
// Mirrors the proto's Three.js MeshStandardMaterial({ map, normalMap, normalScale,
// metalness, roughness }) — cf. docs/design/prototype/scenes/scan-coin-3d.js
// and docs/coin-3d-viewer/porting-android.md (Phase 3, D-PORT-7).

material {
    name : CoinFace,
    shadingModel : lit,
    parameters : [
        { type : sampler2d, name : baseColorMap },
        { type : sampler2d, name : normalMap },
        { type : float,     name : metallic },
        { type : float,     name : roughness },
        { type : float,     name : reflectance },
        { type : float,     name : normalScale }
    ],
    requires : [ uv0, tangents ]
}

fragment {
    void material(inout MaterialInputs material) {
        // Tangent-space normal MUST be set before prepareMaterial (Filament docs).
        // RGB encodes (nx, ny, nz) ∈ [0,1] → decode to [-1,1].
        vec3 n = texture(materialParams_normalMap, getUV0()).xyz * 2.0 - 1.0;
        n.xy *= materialParams.normalScale;
        material.normal = n;
        prepareMaterial(material);

        material.baseColor   = texture(materialParams_baseColorMap, getUV0());
        material.metallic    = materialParams.metallic;
        material.roughness   = materialParams.roughness;
        material.reflectance = materialParams.reflectance;
    }
}
